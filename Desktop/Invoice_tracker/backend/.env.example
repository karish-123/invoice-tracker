NODE_ENV=development
PORT=3000

# Postgres connection string
DATABASE_URL=postgresql://invoice_user:invoice_pass@localhost:5432/invoice_db

# Must be at least 32 characters
JWT_SECRET=change_this_to_a_very_long_random_secret_in_dev_min_32_chars_xxxx
JWT_EXPIRES_IN=7d

BCRYPT_ROUNDS=12

# Allowed CORS origin (use specific origin in production)
CORS_ORIGIN=*
